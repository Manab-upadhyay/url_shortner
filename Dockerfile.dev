FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install all dependencies (including devDependencies)
RUN npm install

# Copy source code
COPY . .

# Expose the API port
EXPOSE 5000

# Start with hot-reloading using the 'dev' script
CMD ["npm", "run", "dev"]
